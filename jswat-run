#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "usage: jswat-run <input.js> [-- wasmtime-args]" >&2
  exit 1
fi

INPUT="$1"
shift

TMPDIR="${TMPDIR:-/tmp}"
OUT="${TMPDIR%/}/jswat-$$.wat"

node "$(dirname "$0")/src/cli.js" compile "$INPUT" --save-wat -o "$OUT" >"/dev/null"

if ! command -v wasmtime >/dev/null 2>&1; then
  echo "error: wasmtime not found in PATH" >&2
  exit 1
fi

wasmtime run "$OUT" "$@"
